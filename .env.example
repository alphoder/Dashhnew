# ────── Database (Neon Postgres) ──────
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/dashh?sslmode=require

# ────── App ──────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────── Solana ──────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
SOLANA_RECIPIENT_ADDRESS=

# ────── Reclaim Protocol ──────
NEXT_PUBLIC_RECLAIM_APP_ID=
NEXT_PUBLIC_RECLAIM_APP_SECRET=
# Legacy (used by the original Instagram flow)
NEXT_PUBLIC_RECLAIM_PROVIDER_ID=
# New multi-platform providers (2.0)
NEXT_PUBLIC_RECLAIM_PROVIDER_ID_INSTAGRAM=
NEXT_PUBLIC_RECLAIM_PROVIDER_ID_YOUTUBE=
NEXT_PUBLIC_RECLAIM_PROVIDER_ID_TWITTER=
NEXT_PUBLIC_RECLAIM_PROVIDER_ID_TIKTOK=

# ────── SIWS Session (2.0) ──────
# Generate a 32+ character random string, e.g. `openssl rand -hex 32`
SIWS_SESSION_SECRET=replace-with-32-plus-char-random-string

# ────── Arweave / Irys (optional) ──────
IRYS_PRIVATE_KEY=
